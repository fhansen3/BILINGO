<aside class="bm-sidebar p-3 d-none d-lg-block">
  <a class="navbar-brand d-flex align-items-center gap-2 mb-4 text-decoration-none" href="dashboard">
    <span style="font-size:1.5rem">🦜</span>
    <span class="fw-bold" style="color: var(--bm-primary)">BiLingo Meet</span>
  </a>
  <nav class="nav flex-column">
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'dashboard') ? 'active' : '' %>" href="dashboard">
      <i class="fa-solid fa-gauge-high me-2"></i> Panel
    </a>
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'partners') ? 'active' : '' %>" href="app/partners">
      <i class="fa-solid fa-user-group me-2"></i> Contactos
    </a>
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'rooms') ? 'active' : '' %>" href="history">
      <i class="fa-solid fa-video me-2"></i> Mis reuniones
    </a>
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'history') ? 'active' : '' %>" href="history">
      <i class="fa-solid fa-clock-rotate-left me-2"></i> Historial
    </a>
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'profile') ? 'active' : '' %>" href="profile">
      <i class="fa-solid fa-user me-2"></i> Perfil
    </a>
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'help') ? 'active' : '' %>" href="help">
      <i class="fa-solid fa-circle-question me-2"></i> Ayuda
    </a>
    <% if (typeof user !== 'undefined' && user && (user.role === 'superadmin' || user.role === 'admin' || user.role === 'company_admin')) { %>
      <hr>
      <a class="nav-link <%= (typeof active !== 'undefined' && active === 'admin') ? 'active' : '' %>" href="admin">
        <i class="fa-solid fa-shield-halved me-2"></i> Administración
      </a>
      <a class="nav-link <%= (typeof active !== 'undefined' && active === 'admin-costs') ? 'active' : '' %>" href="admin/costs">
        <i class="fa-solid fa-chart-line me-2"></i>
        <% if (user.role === 'company_admin') { %>Consumo de mi empresa<% } else { %>Consumos y costos<% } %>
      </a>
      <% if (user.role === 'superadmin' || user.role === 'admin') { %>
        <a class="nav-link <%= (typeof active !== 'undefined' && active === 'admin-users') ? 'active' : '' %>" href="admin/users">
          <i class="fa-solid fa-users-gear me-2"></i> Usuarios
        </a>
        <a class="nav-link <%= (typeof active !== 'undefined' && active === 'admin-companies') ? 'active' : '' %>" href="admin/companies">
          <i class="fa-solid fa-building me-2"></i> Empresas
        </a>
      <% } %>
    <% } %>

    <hr>
    <a class="nav-link <%= (typeof active !== 'undefined' && active === 'help') ? 'active' : '' %>" href="help">
      <i class="fa-solid fa-circle-question me-2"></i> Ayuda
    </a>
  </nav>
</aside>
