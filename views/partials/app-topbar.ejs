<nav class="navbar bm-topbar px-3">
  <div class="container-fluid d-flex justify-content-between align-items-center">
    <button class="btn btn-link d-lg-none p-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#bmSidebarOffcanvas" aria-controls="bmSidebarOffcanvas">
      <i class="fa-solid fa-bars fs-5"></i>
    </button>
    <div class="d-flex align-items-center gap-3 ms-auto">
      <% if (typeof user !== 'undefined' && user) { %>
        <div class="dropdown">
          <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold"
                  style="width:32px;height:32px;background: <%= user.avatar_color || '#4F46E5' %>">
              <%= (user.display_name || user.email || '?').charAt(0).toUpperCase() %>
            </span>
            <span class="d-none d-md-inline"><%= user.display_name || user.email %></span>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="profile"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
            <% if (user.role === 'superadmin' || user.role === 'admin' || user.role === 'company_admin') { %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="admin"><i class="fa-solid fa-shield-halved me-2"></i>Administración</a></li>
              <li><a class="dropdown-item" href="admin/costs"><i class="fa-solid fa-chart-line me-2"></i>Consumos y costos</a></li>
            <% } %>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Salir</a></li>
          </ul>
        </div>
      <% } else { %>
        <a class="btn btn-primary btn-sm" href="login"><i class="fa-solid fa-right-to-bracket me-1"></i> Entrar</a>
      <% } %>
    </div>
  </div>
</nav>
