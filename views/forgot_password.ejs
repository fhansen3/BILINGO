<div class="row justify-content-center py-5">
  <div class="col-12" style="max-width: 440px;">
    <div class="card bm-shadow-sm p-4">
      <div class="text-center mb-4">
        <div class="mb-2" style="font-size:2.5rem">🔑</div>
        <h1 class="h3 fw-bold mb-1">Recuperar contraseña</h1>
        <p class="text-muted small mb-0">Te enviaremos un enlace para restablecerla.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger small py-2 mb-3">
          <i class="fa-solid fa-triangle-exclamation me-1"></i> <%= error %>
        </div>
      <% } %>

      <% if (sent) { %>
        <div class="alert alert-success small py-2 mb-3">
          <i class="fa-solid fa-circle-check me-1"></i>
          Si <strong><%= form.email %></strong> tiene una cuenta, le hemos enviado un enlace para restablecer la contraseña. Revisa tu bandeja de entrada.
        </div>

        <% if (devToken) { %>
          <div class="alert alert-info small py-2 mb-3">
            <i class="fa-solid fa-flask me-1"></i>
            <strong>Modo desarrollo:</strong> el envío de email no está configurado todavía. Usa este enlace directo:
            <div class="mt-2">
              <a href="reset-password/<%= devToken %>" class="text-break"
                 style="font-family: monospace; font-size: 0.8rem;">
                /reset-password/<%= devToken %>
              </a>
            </div>
          </div>
        <% } %>

        <a href="login" class="btn btn-outline-primary w-100">
          <i class="fa-solid fa-arrow-left me-1"></i> Volver a iniciar sesión
        </a>
      <% } else { %>
        <form action="forgot-password" method="post" novalidate>
          <div class="mb-4">
            <label class="form-label small fw-semibold">Email de tu cuenta</label>
            <input
              type="email"
              name="email"
              class="form-control"
              placeholder="tu@email.com"
              value="<%= form.email || '' %>"
              required
              autocomplete="email"
              autofocus
            >
          </div>

          <button type="submit" class="btn btn-primary w-100 btn-lg">
            <i class="fa-solid fa-paper-plane me-1"></i> Enviar enlace
          </button>
        </form>

        <hr class="my-4">

        <p class="text-center text-muted small mb-0">
          ¿Lo recordaste?
          <a href="login" class="fw-semibold">Inicia sesión</a>
        </p>
      <% } %>
    </div>
  </div>
</div>