<%
  function fmtDuration(s) {
    if (!s || s <= 0) return '—';
    var m = Math.round(s / 60);
    return m + ' min';
  }
  function statusBadge(s) {
    if (s === 'active')  return '<span class="badge text-bg-success">En curso</span>';
    if (s === 'waiting') return '<span class="badge text-bg-warning">Esperando</span>';
    if (s === 'open')    return '<span class="badge text-bg-info">Abierta</span>';
    if (s === 'ended' || s === 'closed') return '<span class="badge text-bg-secondary">Terminada</span>';
    return '<span class="badge text-bg-light">' + s + '</span>';
  }
  function fmtDate(d) {
    if (!d) return '—';
    var dt = new Date(d);
    if (isNaN(dt.getTime())) return '—';
    return dt.toLocaleString('es-ES', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
  }
%>

<div class="d-flex" style="min-height: calc(100vh - 60px);">
  <%- include('partials/main-sidebar', { user: user, active: 'dashboard' }) %>

  <div class="flex-grow-1 px-3 px-lg-4 py-3" style="min-width:0">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h1 class="h4 fw-bold mb-1">¡Hola, <%= user.display_name %>! 👋</h1>
        <p class="text-muted small mb-0">¿Listo para tu próxima reunión sin barreras?</p>
      </div>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <div class="d-none d-md-flex gap-2">
          <a href="admin" class="btn btn-outline-primary btn-sm">
            <i class="fa-solid fa-shield-halved me-1"></i> Administración
          </a>
          <a href="admin/costs" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-chart-line me-1"></i> Consumos y costos
          </a>
        </div>
      <% } %>
    </div>

    <% if (typeof isAdmin !== 'undefined' && isAdmin && costTotals) {
       function money(v){ var n=Number(v||0); return '$' + n.toFixed(n < 1 ? 4 : 2); }
       function num(v){ return Number(v||0).toLocaleString('es-ES'); }
       var mins = Number(audioMinutes||0);
       var minsLabel = mins < 1 ? (mins*60).toFixed(0) + ' s' : mins.toFixed(1) + ' min';
       var scopeLabel = (user.role === 'company_admin') ? 'tu empresa' : 'plataforma';
    %>
      <div class="row g-3 mb-4">
        <div class="col-12">
          <div class="text-muted small mb-2">
            <i class="fa-solid fa-circle-info me-1"></i>
            Indicadores de <strong><%= scopeLabel %></strong>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card bm-shadow-sm h-100 p-3 border-0" style="background:var(--bm-surface)">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <span class="text-muted small">Costo hoy</span>
              <span class="rounded-3 d-inline-flex align-items-center justify-content-center"
                    style="width:32px;height:32px;background:#ECFDF5;color:#10B981">
                <i class="fa-solid fa-dollar-sign"></i>
              </span>
            </div>
            <div class="h5 fw-bold mb-0"><%= money(costTotals.cost_today) %></div>
            <div class="text-muted small mt-1">USD en las últimas 24h</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card bm-shadow-sm h-100 p-3 border-0" style="background:var(--bm-surface)">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <span class="text-muted small">Costo 7 días</span>
              <span class="rounded-3 d-inline-flex align-items-center justify-content-center"
                    style="width:32px;height:32px;background:#EFF6FF;color:#2563EB">
                <i class="fa-solid fa-calendar-week"></i>
              </span>
            </div>
            <div class="h5 fw-bold mb-0"><%= money(costTotals.cost_7d) %></div>
            <div class="text-muted small mt-1">USD · 30d: <%= money(costTotals.cost_30d) %></div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card bm-shadow-sm h-100 p-3 border-0" style="background:var(--bm-surface)">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <span class="text-muted small">Tokens totales</span>
              <span class="rounded-3 d-inline-flex align-items-center justify-content-center"
                    style="width:32px;height:32px;background:#FFF7ED;color:#F59E0B">
                <i class="fa-solid fa-coins"></i>
              </span>
            </div>
            <div class="h5 fw-bold mb-0"><%= num(costTotals.tokens_total) %></div>
            <div class="text-muted small mt-1"><%= num(costTotals.calls_total) %> llamadas</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card bm-shadow-sm h-100 p-3 border-0" style="background:var(--bm-surface)">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <span class="text-muted small">Audio procesado</span>
              <span class="rounded-3 d-inline-flex align-items-center justify-content-center"
                    style="width:32px;height:32px;background:#F5F3FF;color:#7C3AED">
                <i class="fa-solid fa-waveform-lines"></i>
              </span>
            </div>
            <div class="h5 fw-bold mb-0"><%= minsLabel %></div>
            <div class="text-muted small mt-1">
              <a href="admin/costs" class="text-decoration-none">Ver detalle →</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Quick action cards -->
    <div class="row g-3 mb-4">
      <div class="col-12 col-md-4">
        <form action="/rooms/new" method="post" class="h-100">
          <button type="submit" class="card bm-shadow-sm h-100 w-100 text-start p-4 border-0" style="cursor:pointer;background:var(--bm-surface)">
            <div class="d-flex align-items-center gap-3">
              <span class="rounded-3 d-inline-flex align-items-center justify-content-center"
                    style="width:48px;height:48px;background:var(--bm-primary-soft);color:var(--bm-primary)">
                <i class="fa-solid fa-video fs-5"></i>
              </span>
              <div>
                <div class="fw-bold">Nueva reunión instantánea</div>
                <div class="text-muted small">Empieza ahora y comparte el enlace</div>
              </div>
            </div>
          </button>
        </form>
      </div>

      <div class="col-12 col-md-4">
        <a href="/schedule" class="card bm-shadow-sm h-100 w-100 text-decoration-none p-4 d-block" style="color:inherit">
          <div class="d-flex align-items-center gap-3">
            <span class="rounded-3 d-inline-flex align-items-center justify-content-center"
                  style="width:48px;height:48px;background:#FFF7ED;color:#F59E0B">
              <i class="fa-solid fa-calendar-plus fs-5"></i>
            </span>
            <div>
              <div class="fw-bold">Programar reunión</div>
              <div class="text-muted small">Elige fecha, hora e invitados</div>
            </div>
          </div>
        </a>
      </div>

      <div class="col-12 col-md-4">
        <div class="card bm-shadow-sm h-100 w-100 p-4">
          <form action="/join" method="post" class="d-flex align-items-center gap-3">
            <span class="rounded-3 d-inline-flex align-items-center justify-content-center flex-shrink-0"
                  style="width:48px;height:48px;background:#ECFDF5;color:#10B981">
              <i class="fa-solid fa-door-open fs-5"></i>
            </span>
            <div class="flex-grow-1">
              <label class="fw-bold small mb-1" for="join-code">Unirse con código</label>
              <div class="input-group input-group-sm">
                <input type="text" id="join-code" name="code" class="form-control form-control-sm" placeholder="ABC-123" maxlength="12" required>
                <button type="submit" class="btn btn-primary btn-sm">Entrar</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Upcoming meetings -->
    <div class="card bm-shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h2 class="h6 fw-bold mb-0"><i class="fa-solid fa-calendar-day me-2 text-primary"></i>Próximas reuniones</h2>
          <a href="/schedule" class="small text-decoration-none">Programar nueva</a>
        </div>

        <% if (!upcoming || !upcoming.length) { %>
          <div class="text-center py-4 text-muted">
            <i class="fa-regular fa-calendar fs-3 mb-2 d-block"></i>
            <p class="small mb-0">No tienes reuniones programadas. <a href="/schedule">Crea la primera</a>.</p>
          </div>
        <% } else { %>
          <div class="list-group list-group-flush">
            <% upcoming.forEach(function(r){ %>
              <div class="list-group-item px-0 d-flex align-items-center justify-content-between">
                <div>
                  <div class="fw-semibold"><%= r.name || r.topic || ('Sala ' + r.room_code) %></div>
                  <div class="text-muted small">
                    Código <code><%= r.room_code %></code>
                    <% if (r.language_focus) { %> · <%= r.language_focus %><% } %>
                    · creada <%= fmtDate(r.created_at) %>
                  </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <%- statusBadge(r.status) %>
                  <a href="/room/<%= r.room_code %>" class="btn btn-sm btn-primary"><i class="fa-solid fa-door-open me-1"></i>Entrar</a>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Recent meetings -->
    <div class="card bm-shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h2 class="h6 fw-bold mb-0"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Recientes</h2>
        </div>

        <% if (!recent || !recent.length) { %>
          <div class="text-center py-4 text-muted">
            <i class="fa-regular fa-folder-open fs-3 mb-2 d-block"></i>
            <p class="small mb-0">Tus reuniones aparecerán aquí cuando empieces a usar BiLingo Meet.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="text-muted small">
                <tr>
                  <th>Sala</th>
                  <th>Tema</th>
                  <th>Idioma</th>
                  <th>Duración</th>
                  <th>Estado</th>
                  <th class="text-end"></th>
                </tr>
              </thead>
              <tbody>
                <% recent.forEach(function(r){ %>
                  <tr>
                    <td>
                      <div class="fw-semibold"><%= r.name || ('Sala ' + r.room_code) %></div>
                      <div class="text-muted small">Código <code><%= r.room_code %></code></div>
                    </td>
                    <td class="text-muted small"><%= r.topic || '—' %></td>
                    <td class="text-muted small"><%= r.language_focus || '—' %></td>
                    <td class="text-muted small"><%= fmtDuration(r.duration_seconds) %></td>
                    <td><%- statusBadge(r.status) %></td>
                    <td class="text-end">
                      <% if (r.status !== 'ended' && r.status !== 'closed') { %>
                        <a href="/room/<%= r.room_code %>" class="btn btn-sm btn-outline-primary">Entrar</a>
                      <% } else { %>
                        <span class="text-muted small"><%= fmtDate(r.ended_at || r.started_at || r.created_at) %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>