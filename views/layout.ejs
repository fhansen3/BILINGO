<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'es' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <%
    // ---------- SEO / OG defaults ----------
    var _title = (typeof title !== 'undefined' && title) ? title :
      'BiLingo Meet — Free real-time translated video meetings in any language';
    var _description = (typeof description !== 'undefined' && description) ? description :
      '🦜 Free video meetings translated live by AI. Talk in your language — everyone hears theirs in real time. Group calls, 30+ languages, no install, works in any browser.';
    var _keywords = (typeof keywords !== 'undefined' && keywords) ? keywords :
      'free video conferencing, multilingual video calls, real-time translation, AI interpreter, live translated meetings, multilingual meetings, free online meetings, video chat translation, real time interpreter, multilingual zoom alternative, free meeting app, translated video conference, language translation meeting, bilingual meetings, international video calls';
    var _ogType = (typeof ogType !== 'undefined' && ogType) ? ogType : 'website';
    var _ogImage = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'images/og-image.png';
    var _ogImageAlt = (typeof ogImageAlt !== 'undefined' && ogImageAlt) ? ogImageAlt :
      'BiLingo Meet — Real-time translated video meetings. Talk in your language, everyone hears theirs.';
    var _canonical = (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : null;
    var _robots = (typeof robots !== 'undefined' && robots) ? robots : 'index,follow';
    var _ogLocale = (typeof ogLocale !== 'undefined' && ogLocale) ? ogLocale : 'en_US';
    var _siteName = 'BiLingo Meet';
    var _twitterSite = (typeof twitterSite !== 'undefined' && twitterSite) ? twitterSite : '';
    var _jsonLd = (typeof jsonLd !== 'undefined' && jsonLd) ? jsonLd : null;
  %>

  <title><%= _title %></title>
  <meta name="description" content="<%= _description %>">
  <meta name="keywords" content="<%= _keywords %>">
  <meta name="robots" content="<%= _robots %>">
  <meta name="author" content="BiLingo Meet">
  <meta name="application-name" content="BiLingo Meet">
  <meta name="theme-color" content="#0B3D91">

  <% if (_canonical) { %>
    <link rel="canonical" href="<%= _canonical %>">
  <% } %>

  <!-- Open Graph (Facebook, WhatsApp, LinkedIn, iMessage, Slack, Telegram, Discord) -->
  <meta property="og:type" content="<%= _ogType %>">
  <meta property="og:site_name" content="<%= _siteName %>">
  <meta property="og:title" content="<%= _title %>">
  <meta property="og:description" content="<%= _description %>">
  <meta property="og:image" content="<%= _ogImage %>">
  <meta property="og:image:alt" content="<%= _ogImageAlt %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/png">
  <meta property="og:locale" content="<%= _ogLocale %>">
  <meta property="og:locale:alternate" content="es_ES">
  <meta property="og:locale:alternate" content="pt_BR">
  <meta property="og:locale:alternate" content="fr_FR">
  <meta property="og:locale:alternate" content="de_DE">
  <meta property="og:locale:alternate" content="it_IT">
  <% if (_canonical) { %>
    <meta property="og:url" content="<%= _canonical %>">
  <% } %>

  <!-- Twitter / X Cards -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= _title %>">
  <meta name="twitter:description" content="<%= _description %>">
  <meta name="twitter:image" content="<%= _ogImage %>">
  <meta name="twitter:image:alt" content="<%= _ogImageAlt %>">
  <% if (_twitterSite) { %>
    <meta name="twitter:site" content="<%= _twitterSite %>">
  <% } %>

  <!-- Favicons / app icons -->
  <link rel="icon" type="image/svg+xml" href="images/logo.svg">
  <link rel="apple-touch-icon" href="images/logo.svg">

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- Inter from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Design system -->
  <link rel="stylesheet" href="css/app.css">

  <% if (_jsonLd) { %>
    <script type="application/ld+json"><%- JSON.stringify(_jsonLd) %></script>
  <% } %>
</head>
<body>
  <% if (typeof nav === 'undefined' || nav === 'public') { %>
    <%- include('partials/top-navbar-public', { user: typeof user !== 'undefined' ? user : null }) %>
  <% } else if (nav === 'app') { %>
    <%- include('partials/app-topbar', { user: typeof user !== 'undefined' ? user : null }) %>
  <% } else if (nav === 'auth-back') { %>
    <%- include('partials/auth-back') %>
  <% } %>

  <main class="container py-4">
    <%- body %>
  </main>

  <!-- Bootstrap 5 JS bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <% if (typeof user !== 'undefined' && user) { %>
    <!-- Realtime notifications (room invitations, etc.) for logged-in users
         viewing server-rendered pages. Mirrors the SPA shell setup. -->
    <script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>
    <script>
      (function () {
        // Minimal UI shim so notifications.js can call window.UI.notify / escapeHtml
        // on EJS pages that don't load the SPA's ui.js.
        if (!window.UI) {
          window.UI = {
            notify: function (msg, type) {
              try { console.log('[notify]', type || 'info', msg); } catch (e) {}
              if (window.bootstrap) {
                var box = document.createElement('div');
                box.className = 'toast align-items-center text-bg-' +
                  ({success:'success', error:'danger', warn:'warning', info:'primary'}[type] || 'primary') +
                  ' border-0 position-fixed';
                box.style.cssText = 'bottom:20px; right:20px; z-index:10000;';
                box.setAttribute('role', 'alert');
                box.innerHTML = '<div class="d-flex"><div class="toast-body">' +
                  String(msg).replace(/</g, '&lt;') + '</div>' +
                  '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
                document.body.appendChild(box);
                var t = new window.bootstrap.Toast(box, { delay: 4000 });
                t.show();
                box.addEventListener('hidden.bs.toast', function () { box.remove(); });
              }
            },
            escapeHtml: function (s) {
              return String(s == null ? '' : s)
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }
          };
        }
        // Router shim so "Unirme" navigates to the room page (server-rendered).
        if (!window.Router) {
          window.Router = {
            navigate: function (path) {
              // path like 'room/<code>' → go to the server-rendered meeting page
              if (/^room\//.test(path)) {
                var code = path.slice(5);
                // BASE_PATH-safe: use relative URL based on <base href>
                window.location.assign('m/' + encodeURIComponent(code));
              } else {
                window.location.assign(path);
              }
            }
          };
        }
        // Minimal API shim (notifications.js calls window.API.post for accept/decline)
        if (!window.API) {
          function apiBase() {
            var b = document.querySelector('base');
            var h = b ? b.getAttribute('href') : '';
            if (!h || h === '/') return '';
            return h.replace(/\/$/, '');
          }
          var BASE = apiBase();
          async function req(p, opts) {
            opts = opts || {};
            var url = (p.indexOf('http') === 0) ? p : (BASE + '/' + p.replace(/^\/+/, ''));
            var headers = Object.assign({ 'Content-Type': 'application/json' }, opts.headers || {});
            var fetchOpts = { method: opts.method || 'GET', credentials: 'include', headers: headers };
            if (opts.body !== undefined) fetchOpts.body = JSON.stringify(opts.body);
            var res = await fetch(url, fetchOpts);
            var text = await res.text();
            var data = null;
            if (text) { try { data = JSON.parse(text); } catch (e) { data = text; } }
            if (!res.ok) {
              var msg = (data && data.error) || ('Error ' + res.status);
              var err = new Error(msg); err.status = res.status; err.data = data; throw err;
            }
            return data;
          }
          window.API = {
            base: BASE,
            get: function (p) { return req(p); },
            post: function (p, b) { return req(p, { method: 'POST', body: b }); }
          };
        }
      })();
    </script>
    <script src="js/notifications.js"></script>
    <script>
      // Boot the notifications socket as soon as the page is ready.
      (function () {
        function boot() {
          if (window.Notifications && typeof window.Notifications.start === 'function') {
            window.Notifications.start();
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', boot);
        } else {
          boot();
        }
      })();
    </script>
  <% } %>
</body>
</html>
