<%
  function fmtDateTime(d) {
    if (!d) return '—';
    var dt = new Date(d);
    if (isNaN(dt.getTime())) return '—';
    return dt.toLocaleString('es-ES', {
      weekday: 'long', day: '2-digit', month: 'long', year: 'numeric',
      hour: '2-digit', minute: '2-digit'
    });
  }
  function statusBadge(s) {
    if (s === 'active')  return '<span class="badge text-bg-success">En curso</span>';
    if (s === 'waiting') return '<span class="badge text-bg-warning">Programada</span>';
    if (s === 'ended' || s === 'closed') return '<span class="badge text-bg-secondary">Terminada</span>';
    return '<span class="badge text-bg-light">' + s + '</span>';
  }
  function inviteStatusBadge(s) {
    if (s === 'pending')   return '<span class="badge text-bg-light">Pendiente</span>';
    if (s === 'accepted')  return '<span class="badge text-bg-success">Aceptada</span>';
    if (s === 'declined')  return '<span class="badge text-bg-danger">Rechazada</span>';
    if (s === 'cancelled') return '<span class="badge text-bg-secondary">Cancelada</span>';
    return '<span class="badge text-bg-light">' + s + '</span>';
  }
%>

<div class="d-flex" style="min-height: calc(100vh - 60px);">
  <%- include('partials/main-sidebar', { user: user, active: 'dashboard' }) %>

  <div class="flex-grow-1 px-3 px-lg-4 py-3" style="min-width:0; max-width: 880px;">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <a href="/dashboard" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Volver al panel
      </a>
      <div><%- statusBadge(meeting.status) %></div>
    </div>

    <div class="card bm-shadow-sm mb-3">
      <div class="card-body p-4">
        <h1 class="h4 fw-bold mb-1">
          <%= meeting.name || meeting.topic || ('Reunión ' + meeting.room_code) %>
        </h1>
        <div class="text-muted small mb-3">
          Organizada por <strong><%= meeting.host_name || '—' %></strong>
        </div>

        <div class="row g-3">
          <div class="col-12 col-md-6">
            <div class="text-muted small mb-1">Fecha y hora</div>
            <div class="fw-semibold">
              <% if (meeting.scheduled_start) { %>
                <%= fmtDateTime(meeting.scheduled_start) %>
              <% } else if (meeting.started_at) { %>
                Empezó: <%= fmtDateTime(meeting.started_at) %>
              <% } else { %>
                Reunión instantánea
              <% } %>
            </div>
          </div>
          <div class="col-12 col-md-6">
            <div class="text-muted small mb-1">Código de reunión</div>
            <div class="d-flex align-items-center gap-2">
              <code class="fs-5"><%= meeting.room_code %></code>
              <button type="button" class="btn btn-sm btn-outline-secondary"
                      data-copy-code="<%= meeting.room_code %>" title="Copiar código">
                <i class="fa-regular fa-copy"></i>
              </button>
            </div>
          </div>
        </div>

        <% if (meeting.topic) { %>
          <div class="mt-3">
            <div class="text-muted small mb-1">Tema</div>
            <div><%= meeting.topic %></div>
          </div>
        <% } %>

        <hr class="my-4">

        <div class="d-flex flex-column flex-md-row gap-2 align-items-stretch align-items-md-center">
          <div class="flex-grow-1">
            <div class="text-muted small mb-1">Enlace para compartir</div>
            <div class="input-group">
              <input type="text" id="join-link" class="form-control"
                     value="<%= joinUrl %>" readonly>
              <button type="button" class="btn btn-outline-secondary" id="copy-link">
                <i class="fa-regular fa-copy me-1"></i>Copiar
              </button>
            </div>
          </div>
          <a href="/m/<%= meeting.room_code %>/lobby" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-door-open me-1"></i>Unirse
          </a>
        </div>
      </div>
    </div>

    <% if (isHost) { %>
      <div class="card bm-shadow-sm">
        <div class="card-body p-4">
          <h2 class="h6 fw-bold mb-3">
            <i class="fa-regular fa-envelope me-2 text-primary"></i>Invitados
            <span class="text-muted small fw-normal">(<%= invitations.length %>)</span>
          </h2>

          <% if (!invitations.length) { %>
            <p class="text-muted small mb-0">No has invitado a nadie aún. Comparte el enlace para que se unan.</p>
          <% } else { %>
            <ul class="list-group list-group-flush">
              <% invitations.forEach(function(inv){ %>
                <li class="list-group-item px-0 d-flex align-items-center justify-content-between">
                  <div class="text-truncate">
                    <i class="fa-regular fa-user me-2 text-muted"></i><%= inv.email %>
                  </div>
                  <%- inviteStatusBadge(inv.status) %>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  (function(){
    var btn = document.getElementById('copy-link');
    var input = document.getElementById('join-link');
    if (btn && input) {
      btn.addEventListener('click', function(){
        input.select();
        try {
          navigator.clipboard.writeText(input.value);
        } catch(e) {
          document.execCommand && document.execCommand('copy');
        }
        var orig = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check me-1"></i>Copiado';
        setTimeout(function(){ btn.innerHTML = orig; }, 1500);
      });
    }
    document.querySelectorAll('[data-copy-code]').forEach(function(b){
      b.addEventListener('click', function(){
        var code = b.getAttribute('data-copy-code');
        try { navigator.clipboard.writeText(code); } catch(e){}
        var orig = b.innerHTML;
        b.innerHTML = '<i class="fa-solid fa-check"></i>';
        setTimeout(function(){ b.innerHTML = orig; }, 1200);
      });
    });
  })();
</script>