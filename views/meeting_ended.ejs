<%
  var m = meeting || {};
  var langs = languages || [];
  var parts = participants || [];
  var stats = stats || {};

  function fmtDuration(s) {
    if (!s || s <= 0) return '0 min';
    var h = Math.floor(s / 3600);
    var min = Math.floor((s % 3600) / 60);
    var sec = s % 60;
    if (h > 0) return h + 'h ' + min + 'min';
    if (min > 0) return min + ' min ' + (sec ? sec + 's' : '');
    return sec + 's';
  }
%>
<div class="row justify-content-center">
  <div class="col-lg-9">
    <div class="card bm-shadow-sm mb-4">
      <div class="card-body text-center p-4">
        <div class="mb-3">
          <i class="fa-solid fa-circle-check text-success" style="font-size:3rem;"></i>
        </div>
        <h4 class="mb-2">Has salido de la reunión</h4>
        <p class="text-muted mb-3">
          <%= m.name || ('Reunión ' + m.room_code) %>
        </p>
        <div class="text-muted small mb-2">
          Código: <code><%= m.room_code %></code>
        </div>

        <div class="row g-3 my-3 text-center">
          <div class="col-6 col-md-3">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-muted small text-uppercase">Duración</div>
              <div class="h5 fw-bold mb-0"><%= fmtDuration(m.duration_seconds || stats.duration_seconds) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-muted small text-uppercase">Participantes</div>
              <div class="h5 fw-bold mb-0"><%= parts.length %></div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-muted small text-uppercase">Idiomas</div>
              <div class="h5 fw-bold mb-0"><%= langs.length %></div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-muted small text-uppercase">Mensajes</div>
              <div class="h5 fw-bold mb-0"><%= stats.messages || 0 %></div>
            </div>
          </div>
        </div>

        <% if (parts.length) { %>
          <div class="mb-3 text-start">
            <div class="text-muted small mb-2"><i class="fa-solid fa-users me-1"></i> Participantes</div>
            <div class="d-flex flex-wrap gap-2">
              <% parts.forEach(function(p){ %>
                <span class="badge text-bg-light border"><i class="fa-solid fa-user me-1 text-muted"></i><%= p.display_name %></span>
              <% }); %>
            </div>
          </div>
        <% } %>

        <% if (langs.length) { %>
          <div class="mb-3 text-start">
            <div class="text-muted small mb-2"><i class="fa-solid fa-language me-1"></i> Idiomas usados</div>
            <div class="d-flex flex-wrap gap-2">
              <% langs.forEach(function(l){ %>
                <span class="badge text-bg-info"><%= l %></span>
              <% }); %>
            </div>
          </div>
        <% } %>

        <% if (m.save_transcript) { %>
          <hr>
          <div class="text-start">
            <div class="text-muted small mb-2"><i class="fa-solid fa-file-arrow-down me-1"></i> Descargar transcripción</div>
            <div class="d-flex flex-wrap gap-2">
              <a href="/m/<%= m.room_code %>/transcript.txt" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-file-lines me-1"></i> .txt
              </a>
              <a href="/m/<%= m.room_code %>/transcript.json" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-file-code me-1"></i> .json
              </a>
            </div>
          </div>
        <% } else { %>
          <hr>
          <div class="text-start text-muted small">
            <i class="fa-solid fa-lock me-1"></i>
            La transcripción de esta reunión no se guardó (configuración del anfitrión).
          </div>
        <% } %>

        <div class="d-flex gap-2 justify-content-center mt-4">
          <a href="/dashboard" class="btn btn-primary">
            <i class="fa-solid fa-house me-1"></i> Volver al panel
          </a>
          <a href="/history" class="btn btn-outline-secondary">
            <i class="fa-solid fa-clock-rotate-left me-1"></i> Historial
          </a>
        </div>
      </div>
    </div>

    <!-- Feedback form -->
    <div class="card bm-shadow-sm">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="fa-solid fa-star-half-stroke text-warning me-2"></i>Cuéntanos cómo fue</h5>

        <% if (typeof feedbackSaved !== 'undefined' && feedbackSaved) { %>
          <div class="alert alert-success">
            <i class="fa-solid fa-circle-check me-1"></i> ¡Gracias por tu valoración!
          </div>
        <% } else { %>
          <% if (typeof feedbackError !== 'undefined' && feedbackError) { %>
            <div class="alert alert-danger"><%= feedbackError %></div>
          <% } %>
          <form method="post" action="/m/<%= m.room_code %>/feedback">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Calidad de traducción</label>
                <div class="btn-group d-flex" role="group" aria-label="Calidad de traducción">
                  <% for (var i=1;i<=5;i++) { %>
                    <input type="radio" class="btn-check" name="translationQuality" id="tq<%=i%>" value="<%=i%>" <%= i===5?'checked':'' %>>
                    <label class="btn btn-outline-warning" for="tq<%=i%>"><%=i%> <i class="fa-solid fa-star"></i></label>
                  <% } %>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Calidad de audio</label>
                <div class="btn-group d-flex" role="group" aria-label="Calidad de audio">
                  <% for (var i=1;i<=5;i++) { %>
                    <input type="radio" class="btn-check" name="audioQuality" id="aq<%=i%>" value="<%=i%>" <%= i===5?'checked':'' %>>
                    <label class="btn btn-outline-warning" for="aq<%=i%>"><%=i%> <i class="fa-solid fa-star"></i></label>
                  <% } %>
                </div>
              </div>
              <div class="col-12">
                <label class="form-label fw-semibold" for="fb-comments">Comentarios</label>
                <textarea id="fb-comments" name="comments" rows="3" maxlength="2000" class="form-control" placeholder="¿Qué te pareció la reunión?"></textarea>
              </div>
            </div>
            <div class="text-end mt-3">
              <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-paper-plane me-1"></i> Enviar valoración
              </button>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>