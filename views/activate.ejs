<div class="container py-5" style="max-width:480px;">
  <div class="text-center mb-4">
    <i class="fa-solid fa-user-check" style="font-size:48px;color:#58CC02;"></i>
    <h1 class="h3 mt-3">Activar tu cuenta</h1>
    <p class="text-muted mb-0">Elige una contraseña para empezar a usar BiLingo Meet.</p>
  </div>

  <% if (!valid) { %>
    <div class="alert alert-danger">
      <i class="fa-solid fa-triangle-exclamation me-2"></i>
      <%= error || 'Enlace inválido o caducado.' %>
    </div>
    <div class="text-center">
      <a href="login" class="btn btn-outline-secondary">Volver a iniciar sesión</a>
    </div>
  <% } else { %>
    <div class="card shadow-sm">
      <div class="card-body">
        <% if (typeof activationEmail !== 'undefined' && activationEmail) { %>
          <div class="mb-3 small text-muted">
            Cuenta: <strong><%= activationName || '' %></strong>
            (<%= activationEmail %>)
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-danger small"><%= error %></div>
        <% } %>
        <form method="post" action="activate/<%= token %>">
          <div class="mb-3">
            <label class="form-label">Nueva contraseña</label>
            <input type="password" class="form-control" name="password" required minlength="6" autofocus>
            <div class="form-text">Mínimo 6 caracteres.</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Confirmar contraseña</label>
            <input type="password" class="form-control" name="confirm" required minlength="6">
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="fa-solid fa-check me-1"></i> Activar cuenta
          </button>
        </form>
      </div>
    </div>
  <% } %>
</div>
