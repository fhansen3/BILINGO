<div class="row justify-content-center py-5">
  <div class="col-12" style="max-width: 440px;">
    <div class="card bm-shadow-sm p-4">
      <div class="text-center mb-4">
        <div class="mb-2" style="font-size:2.5rem">🔒</div>
        <h1 class="h3 fw-bold mb-1">Nueva contraseña</h1>
        <p class="text-muted small mb-0">Elige una contraseña segura para tu cuenta.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger small py-2 mb-3">
          <i class="fa-solid fa-triangle-exclamation me-1"></i> <%= error %>
        </div>
      <% } %>

      <% if (valid) { %>
        <form action="/reset-password/<%= token %>" method="post" novalidate>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Nueva contraseña</label>
            <input
              type="password"
              name="password"
              class="form-control"
              placeholder="Mínimo 6 caracteres"
              minlength="6"
              required
              autocomplete="new-password"
              autofocus
            >
          </div>
          <div class="mb-4">
            <label class="form-label small fw-semibold">Confirma la contraseña</label>
            <input
              type="password"
              name="confirm"
              class="form-control"
              placeholder="Repite tu contraseña"
              minlength="6"
              required
              autocomplete="new-password"
            >
          </div>

          <button type="submit" class="btn btn-primary w-100 btn-lg">
            <i class="fa-solid fa-key me-1"></i> Guardar contraseña
          </button>
        </form>
      <% } else { %>
        <p class="text-center text-muted small mb-4">
          Pide un nuevo enlace de recuperación desde la página de contraseña olvidada.
        </p>
        <a href="/forgot-password" class="btn btn-primary w-100 btn-lg">
          <i class="fa-solid fa-rotate-right me-1"></i> Pedir nuevo enlace
        </a>
      <% } %>

      <hr class="my-4">

      <p class="text-center text-muted small mb-0">
        <a href="/login" class="fw-semibold">
          <i class="fa-solid fa-arrow-left me-1"></i> Volver a iniciar sesión
        </a>
      </p>
    </div>
  </div>
</div>