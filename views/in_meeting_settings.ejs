<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E🦜%3C/text%3E%3C/svg%3E">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --bm-bg: #0F172A;
      --bm-panel: #111827;
      --bm-panel-2: #1F2937;
      --bm-border: #374151;
      --bm-muted: #94A3B8;
      --bm-text: #F8FAFC;
      --bm-accent: #3B82F6;
      --bm-danger: #EF4444;
      --bm-success: #10B981;
    }
    html, body {
      background: var(--bm-bg);
      color: var(--bm-text);
      font-family: 'Inter', system-ui, sans-serif;
      height: 100%;
      margin: 0;
    }
    body { display: flex; flex-direction: column; }

    .bm-back-stage {
      position: fixed; inset: 0;
      display: flex; align-items: center; justify-content: center;
      color: var(--bm-muted);
      text-align: center;
      padding: 24px;
    }
    .bm-back-stage h2 { color: var(--bm-text); font-size: 1.1rem; }
    .bm-back-stage a { color: var(--bm-accent); }

    .offcanvas {
      background: var(--bm-panel) !important;
      color: var(--bm-text) !important;
      border-left: 1px solid var(--bm-border) !important;
      width: 460px !important;
      max-width: 100vw !important;
    }
    .offcanvas-header {
      border-bottom: 1px solid var(--bm-border);
      padding: 14px 18px;
    }
    .offcanvas-title { font-weight: 700; }
    .btn-close { filter: invert(1) grayscale(100%) brightness(200%); }

    .nav-tabs {
      border-bottom: 1px solid var(--bm-border);
      padding: 0 12px;
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
    }
    .nav-tabs .nav-item .nav-link {
      color: var(--bm-muted);
      background: transparent;
      border: 0;
      border-bottom: 2px solid transparent;
      padding: 10px 12px;
      font-size: 0.82rem;
      font-weight: 600;
      white-space: nowrap;
    }
    .nav-tabs .nav-item .nav-link.active {
      color: var(--bm-text);
      background: transparent;
      border-bottom-color: var(--bm-accent);
    }
    .tab-pane { padding: 16px 18px; }

    label.form-label {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--bm-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 6px;
    }
    .form-select, .form-control {
      background: var(--bm-panel-2);
      color: var(--bm-text);
      border: 1px solid var(--bm-border);
    }
    .form-select:focus, .form-control:focus {
      background: var(--bm-panel-2);
      color: var(--bm-text);
      border-color: var(--bm-accent);
      box-shadow: 0 0 0 0.2rem rgba(59,130,246,0.18);
    }
    .form-check-input {
      background-color: var(--bm-panel-2);
      border-color: var(--bm-border);
    }
    .form-check-input:checked {
      background-color: var(--bm-accent);
      border-color: var(--bm-accent);
    }
    .form-range::-webkit-slider-thumb { background: var(--bm-accent); }
    .form-range::-moz-range-thumb { background: var(--bm-accent); }

    .bm-setting-row {
      padding: 10px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .bm-setting-row:last-child { border-bottom: 0; }
    .bm-setting-help {
      color: var(--bm-muted);
      font-size: 0.74rem;
      margin-top: 4px;
    }
    .bm-slider-row {
      display: flex; align-items: center; gap: 10px;
    }
    .bm-slider-row .form-range { flex: 1 1 auto; }
    .bm-slider-val {
      min-width: 52px; text-align: right;
      font-variant-numeric: tabular-nums;
      color: var(--bm-text);
      font-weight: 600;
      font-size: 0.85rem;
    }
    .bm-radio-group {
      display: flex; gap: 6px; flex-wrap: wrap;
    }
    .bm-radio-group input[type="radio"] { display: none; }
    .bm-radio-group label {
      flex: 1 1 0;
      min-width: 80px;
      padding: 8px 10px;
      border: 1px solid var(--bm-border);
      border-radius: 8px;
      text-align: center;
      cursor: pointer;
      background: var(--bm-panel-2);
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--bm-text);
      margin: 0;
    }
    .bm-radio-group input[type="radio"]:checked + label {
      border-color: var(--bm-accent);
      background: rgba(59,130,246,0.18);
      color: #fff;
    }

    .bm-save-bar {
      position: sticky; bottom: 0;
      background: var(--bm-panel);
      border-top: 1px solid var(--bm-border);
      padding: 12px 18px;
      display: flex; gap: 8px; justify-content: flex-end;
    }
    .bm-alert {
      margin: 12px 18px 0;
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 0.85rem;
    }
    .bm-alert.error {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.45);
      color: #FECACA;
    }
    .bm-alert.success {
      background: rgba(16,185,129,0.15);
      border: 1px solid rgba(16,185,129,0.45);
      color: #A7F3D0;
    }
  </style>
</head>
<body>
  <%
    var m = meeting || {};
    var p = participant || {};
    var langs = languages || [];
  %>

  <div class="bm-back-stage">
    <div>
      <h2><i class="fa-solid fa-gear me-2"></i>Configuración de la reunión</h2>
      <p class="mb-2">Ajusta tus preferencias de audio, idioma y subtítulos.</p>
      <a href="m/<%= m.room_code %>/room"><i class="fa-solid fa-arrow-left me-1"></i>Volver a la sala</a>
    </div>
  </div>

  <div class="offcanvas offcanvas-end show" tabindex="-1" id="bmSettingsDrawer" data-bs-scroll="true" data-bs-backdrop="false" style="visibility:visible;">
    <div class="offcanvas-header">
      <h5 class="offcanvas-title"><i class="fa-solid fa-gear me-2"></i>Configuración</h5>
      <a href="m/<%= m.room_code %>/room" class="btn-close" aria-label="Cerrar"></a>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bm-alert error"><%= error %></div>
    <% } %>
    <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="bm-alert success"><i class="fa-solid fa-check me-1"></i>Cambios guardados.</div>
    <% } %>

    <form method="POST" action="m/<%= m.room_code %>/participants/me" id="bm-settings-form" style="display:flex; flex-direction:column; flex:1 1 auto; min-height:0;">
      <ul class="nav nav-tabs" id="bm-settings-tabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" type="button" data-bs-toggle="tab" data-bs-target="#tab-audio">
            <i class="fa-solid fa-volume-high me-1"></i> Audio
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" type="button" data-bs-toggle="tab" data-bs-target="#tab-video">
            <i class="fa-solid fa-video me-1"></i> Video
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" type="button" data-bs-toggle="tab" data-bs-target="#tab-lang">
            <i class="fa-solid fa-language me-1"></i> Idioma y voz
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" type="button" data-bs-toggle="tab" data-bs-target="#tab-cap">
            <i class="fa-solid fa-closed-captioning me-1"></i> Subtítulos
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" type="button" data-bs-toggle="tab" data-bs-target="#tab-net">
            <i class="fa-solid fa-signal me-1"></i> Red
          </button>
        </li>
      </ul>

      <div class="tab-content" style="flex:1 1 auto; overflow-y:auto;">

        <!-- AUDIO TAB -->
        <div class="tab-pane fade show active" id="tab-audio" role="tabpanel">
          <div class="bm-setting-row">
            <label class="form-label">Volumen de la voz original</label>
            <div class="bm-slider-row">
              <input type="range" min="0" max="100" step="1"
                     class="form-range" name="originalVolume"
                     value="<%= p.original_volume != null ? p.original_volume : 40 %>"
                     oninput="document.getElementById('val-origVol').textContent = this.value + '%';">
              <span class="bm-slider-val" id="val-origVol"><%= (p.original_volume != null ? p.original_volume : 40) %>%</span>
            </div>
            <div class="bm-setting-help">Audio del otro participante en su idioma original (mezclado por debajo de la traducción).</div>
          </div>

          <div class="bm-setting-row">
            <label class="form-label">Volumen de la voz traducida</label>
            <div class="bm-slider-row">
              <input type="range" min="0" max="100" step="1"
                     class="form-range" name="translatedVolume"
                     value="<%= p.translated_volume != null ? p.translated_volume : 100 %>"
                     oninput="document.getElementById('val-trVol').textContent = this.value + '%';">
              <span class="bm-slider-val" id="val-trVol"><%= (p.translated_volume != null ? p.translated_volume : 100) %>%</span>
            </div>
            <div class="bm-setting-help">Audio principal: tu idioma nativo, generado por la traducción.</div>
          </div>
        </div>

        <!-- VIDEO TAB -->
        <div class="tab-pane fade" id="tab-video" role="tabpanel">
          <div class="bm-setting-row">
            <label class="form-label">Cámara</label>
            <select class="form-select" disabled>
              <option>Cámara predeterminada del sistema</option>
            </select>
            <div class="bm-setting-help">La selección de dispositivos se aplica en tu navegador antes de unirte al lobby.</div>
          </div>
          <div class="bm-setting-row">
            <label class="form-label">Calidad de video</label>
            <select class="form-select" disabled>
              <option>Automática (recomendado)</option>
            </select>
            <div class="bm-setting-help">El servidor ajusta automáticamente la calidad según la red.</div>
          </div>
        </div>

        <!-- LANGUAGE & VOICE TAB -->
        <div class="tab-pane fade" id="tab-lang" role="tabpanel">
          <div class="bm-setting-row">
            <label class="form-label">Idioma nativo (lo que hablas)</label>
            <select name="nativeLanguage" class="form-select">
              <% langs.forEach(function(L){ %>
                <option value="<%= L.code %>" <%= (p.native_language === L.code) ? 'selected' : '' %>>
                  <%= L.name %><%= L.native_name && L.native_name !== L.name ? ' — ' + L.native_name : '' %>
                </option>
              <% }); %>
            </select>
          </div>

          <div class="bm-setting-row">
            <label class="form-label">Idioma objetivo (lo que quieres escuchar)</label>
            <select name="targetLanguage" class="form-select">
              <% langs.forEach(function(L){ %>
                <option value="<%= L.code %>" <%= (p.target_language === L.code) ? 'selected' : '' %>>
                  <%= L.name %><%= L.native_name && L.native_name !== L.name ? ' — ' + L.native_name : '' %>
                </option>
              <% }); %>
            </select>
          </div>

          <div class="bm-setting-row">
            <label class="form-label">Tu voz (cómo te oirán los demás)</label>
            <div class="bm-radio-group">
              <input type="radio" id="spk-male"    name="speakingVoiceGender" value="male"    <%= p.speaking_voice_gender === 'male' ? 'checked' : '' %>>
              <label for="spk-male"><i class="fa-solid fa-person me-1"></i>Masculina</label>

              <input type="radio" id="spk-female"  name="speakingVoiceGender" value="female"  <%= p.speaking_voice_gender === 'female' || !p.speaking_voice_gender ? 'checked' : '' %>>
              <label for="spk-female"><i class="fa-solid fa-person-dress me-1"></i>Femenina</label>

              <input type="radio" id="spk-neutral" name="speakingVoiceGender" value="neutral" <%= p.speaking_voice_gender === 'neutral' ? 'checked' : '' %>>
              <label for="spk-neutral"><i class="fa-solid fa-circle me-1"></i>Neutra</label>
            </div>
          </div>

          <div class="bm-setting-row">
            <label class="form-label">Voz para escuchar (cómo oirás a los demás)</label>
            <div class="bm-radio-group">
              <input type="radio" id="lst-male"    name="listeningVoiceGender" value="male"    <%= p.listening_voice_gender === 'male' ? 'checked' : '' %>>
              <label for="lst-male"><i class="fa-solid fa-person me-1"></i>Masculina</label>

              <input type="radio" id="lst-female"  name="listeningVoiceGender" value="female"  <%= p.listening_voice_gender === 'female' || !p.listening_voice_gender ? 'checked' : '' %>>
              <label for="lst-female"><i class="fa-solid fa-person-dress me-1"></i>Femenina</label>

              <input type="radio" id="lst-neutral" name="listeningVoiceGender" value="neutral" <%= p.listening_voice_gender === 'neutral' ? 'checked' : '' %>>
              <label for="lst-neutral"><i class="fa-solid fa-circle me-1"></i>Neutra</label>
            </div>
          </div>

          <div class="bm-setting-row">
            <label class="form-label">Modo de entrega</label>
            <div class="bm-radio-group">
              <input type="radio" id="dm-voice" name="deliveryMode" value="voice" <%= p.delivery_mode === 'voice' ? 'checked' : '' %>>
              <label for="dm-voice"><i class="fa-solid fa-volume-high me-1"></i>Voz</label>

              <input type="radio" id="dm-text"  name="deliveryMode" value="text"  <%= p.delivery_mode === 'text' ? 'checked' : '' %>>
              <label for="dm-text"><i class="fa-solid fa-font me-1"></i>Texto</label>

              <input type="radio" id="dm-both"  name="deliveryMode" value="both"  <%= !p.delivery_mode || p.delivery_mode === 'both' ? 'checked' : '' %>>
              <label for="dm-both"><i class="fa-solid fa-grip-vertical me-1"></i>Ambos</label>
            </div>
            <div class="bm-setting-help">"Ambos" mezcla voz traducida + subtítulos.</div>
          </div>
        </div>

        <!-- CAPTIONS TAB -->
        <div class="tab-pane fade" id="tab-cap" role="tabpanel">
          <div class="bm-setting-row">
            <label class="form-label d-block">Subtítulos</label>
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" role="switch"
                     id="captionsEnabled" name="captionsEnabled" value="1"
                     <%= p.captions_enabled ? 'checked' : '' %>>
              <label class="form-check-label" for="captionsEnabled" style="color:var(--bm-text); text-transform:none; letter-spacing:0;">
                Mostrar subtítulos en cada tile
              </label>
            </div>
            <div class="bm-setting-help">Muestra la transcripción traducida y, en gris, el texto original.</div>
          </div>
        </div>

        <!-- NETWORK TAB -->
        <div class="tab-pane fade" id="tab-net" role="tabpanel">
          <div class="bm-setting-row">
            <label class="form-label">Retraso manual adicional (ms)</label>
            <div class="bm-slider-row">
              <input type="range" min="0" max="5000" step="100"
                     class="form-range" name="manualExtraDelayMs"
                     value="<%= p.manual_extra_delay_ms != null ? p.manual_extra_delay_ms : 0 %>"
                     oninput="document.getElementById('val-delay').textContent = this.value + ' ms';">
              <span class="bm-slider-val" id="val-delay"><%= (p.manual_extra_delay_ms != null ? p.manual_extra_delay_ms : 0) %> ms</span>
            </div>
            <div class="bm-setting-help">Sumar un retraso fijo antes de reproducir la traducción para suavizar la sincronización labial. Máx. 5000 ms.</div>
          </div>
        </div>

      </div>

      <div class="bm-save-bar">
        <a href="m/<%= m.room_code %>/room" class="btn btn-outline-light btn-sm">Cancelar</a>
        <button type="submit" class="btn btn-primary btn-sm">
          <i class="fa-solid fa-floppy-disk me-1"></i> Guardar
        </button>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Auto-redirect to /room if user closes the drawer by hitting Esc.
    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape') window.location.href = (document.querySelector('base')?.getAttribute('href') || '') + 'm/<%= m.room_code %>/room';
    });
  </script>
</body>
</html>